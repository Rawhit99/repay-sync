        {
          "name": "Assign Customer to Officer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "",
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.test('Officer assigned', () => {",
                  "    pm.expect(json.assigned_officer).to.be.an('object');",
                  "    pm.expect(json.assigned_officer.email).to.eql(pm.collectionVariables.get('officerEmail'));",
                  "  });",
                  "  if (json.id) {",
                  "    pm.collectionVariables.set('customerId', json.id);",
                  "  }",
                  "  console.log('Assigned to:', json.assigned_officer.email);",
                  "}"
